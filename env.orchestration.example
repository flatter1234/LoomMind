# 编排层与会话入口相关（可选）
# 复制所需行到仓库根目录 `.env` 即可；根目录 `.env.example` 仅保留通用项并指向本文件。

# 编排层：不设或为 0/false/new 时使用 triage + simple|complex；设为 legacy/old/true/1 等则退回单张规划图
# （CLI、`--cli --stdio`、飞书 `--lark` 均读此变量，无单独入口开关）
LOOMMIND_ORCHESTRATION=
# 顶层审校因 reject 打回下层的最多次数（默认 2）；设为 0 则首次 reject 即走 review_cap 强制定稿
LOOMMIND_MAX_REVIEW_REJECT_RETRIES=
# 每轮打印 orchestration_metadata JSON 到 stdout（默认 1）；设为 0/false/no 可关闭
LOOMMIND_ORCHESTRATION_LOG_METADATA=
# 模块主管子图单任务规划循环上限（未设时取 min(父图上限, 8) 与 3 的 max）
LOOMMIND_SUBTASK_MAX_PLAN_CYCLES=
# 子任务 role 覆盖模型（可选）：code / reasoning / generic
LOOMMIND_MODEL_ROLE_CODE=
LOOMMIND_MODEL_ROLE_REASONING=
LOOMMIND_MODEL_ROLE_GENERIC=
