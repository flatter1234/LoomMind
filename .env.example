LOOMMIND_LLM_PROVIDER= # openrouter; ollama

# openrouter
OPENROUTER_API_KEY=

# ollama
OLLAMA_BASE_URL= # default: http://127.0.0.1:11434/v1 or http://host:11434/v1
OLLAMA_MODEL= # 默认模型；不填则用本机 ollama tags 列表的第一个，失败时回退 llama3.2
OLLAMA_API_KEY=

# 单条用户消息内规划循环上限（thought→工具→观察 为一轮计数基数）；默认 6，最大 64
LOOMMIND_MAX_PLAN_CYCLES=

# feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_USER_ACCESS_TOKEN=
